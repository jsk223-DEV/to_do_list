<%- include('partials/header.ejs') %>

<main>
	<div id="nav">
		<button title="Add Section" id="add_section" onclick="addSection()"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-icon lucide-plus"><path d="M5 12h14"/><path d="M12 5v14"/></svg></button>
        <% if(locals.sections){sections.forEach((sect, index) => {  %>
		    <button style="background-color: rgb(<%= sect.color %>);" data-id="<%= sect.id  %>" onclick="scrollToSection(<%= sect.id %>)" class="<%= index == 0 ? 'active' : '' %>"><%= sect.title %></button>
        <% })} %>
	</div>
	<div id="section_container">
		<div class="spacer"></div>
        <% if(locals.sections) {sections.forEach((sect, sIndex) => { let color = sect.color.split(',');%>
		<div style="--r: <%=color[0] %>; --g: <%=color[1] %>; --b: <%=color[2]%>" class="section <%= sIndex == 0 ? 'selected' : ''  %>" data-id="<%= sect.id %>">
			<div class="top-bar">
				<input onchange="updateSectionTitle(<%= sect.id %>, this.value)" class="title" value="<%= sect.title %>" />
                <div class="buttons">
                <button onclick="addToDo(this.parentElement.parentElement.parentElement)" class="button" title="Add To Do" >
                    <svg 
                        xmlns="http://www.w3.org/2000/svg" 
                        width="24" 
                        height="24" 
                        viewBox="0 0 24 24" 
                        fill="none" 
                        stroke="currentColor" 
                        stroke-width="2" 
                        stroke-linecap="round" 
                        stroke-linejoin="round" 
                        class="lucide lucide-plus-icon lucide-plus">
                        <path d="M5 12h14"/><path d="M12 5v14"/>
                    </svg>
                </button>
				<!-- <a class="button" href="" title="Edit Section Theme">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-paintbrush-icon lucide-paintbrush"
					>
						<path d="m14.622 17.897-10.68-2.913" />
						<path
							d="M18.376 2.622a1 1 0 1 1 3.002 3.002L17.36 9.643a.5.5 0 0 0 0 .707l.944.944a2.41 2.41 0 0 1 0 3.408l-.944.944a.5.5 0 0 1-.707 0L8.354 7.348a.5.5 0 0 1 0-.707l.944-.944a2.41 2.41 0 0 1 3.408 0l.944.944a.5.5 0 0 0 .707 0z"
						/>
						<path
							d="M9 8c-1.804 2.71-3.97 3.46-6.583 3.948a.507.507 0 0 0-.302.819l7.32 8.883a1 1 0 0 0 1.185.204C12.735 20.405 16 16.792 16 15"
						/></svg
				></a> -->
				<label for="color_<%= sect.id %>" class="button" title="Edit Section Theme"><svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-paintbrush-icon lucide-paintbrush"
					>
						<path d="m14.622 17.897-10.68-2.913" />
						<path
							d="M18.376 2.622a1 1 0 1 1 3.002 3.002L17.36 9.643a.5.5 0 0 0 0 .707l.944.944a2.41 2.41 0 0 1 0 3.408l-.944.944a.5.5 0 0 1-.707 0L8.354 7.348a.5.5 0 0 1 0-.707l.944-.944a2.41 2.41 0 0 1 3.408 0l.944.944a.5.5 0 0 0 .707 0z"
						/>
						<path
							d="M9 8c-1.804 2.71-3.97 3.46-6.583 3.948a.507.507 0 0 0-.302.819l7.32 8.883a1 1 0 0 0 1.185.204C12.735 20.405 16 16.792 16 15"
						/></svg
				></label>
				<input list="colors" id="color_<%= sect.id %>" type="color" class="color-input" onchange="sectionThemeChange(this.value, <%= sect.id %>)" oninput="sectionThemeInput(this.value, <%= sect.id %>)" >
				<button title="Move Section" class="button move" onmousedown="startMove(event, this.parentElement.parentElement.parentElement, this.parentElement.parentElement.parentElement.parentElement)"
					>
                    <div id="overlay"></div>
                    <svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="black"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-grip-icon lucide-grip"
					>
						<circle cx="12" cy="5" r="1" />
						<circle cx="19" cy="5" r="1" />
						<circle cx="5" cy="5" r="1" />
						<circle cx="12" cy="12" r="1" />
						<circle cx="19" cy="12" r="1" />
						<circle cx="5" cy="12" r="1" />
						<circle cx="12" cy="19" r="1" />
						<circle cx="19" cy="19" r="1" />
						<circle cx="5" cy="19" r="1" /></svg
				></button>
				<button class="button" onclick="deleteSection(<%= sect.id %>)" title="Delete Section">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="darkred"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-trash2-icon lucide-trash-2"
					>
						<path d="M10 11v6" />
						<path d="M14 11v6" />
						<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
						<path d="M3 6h18" />
						<path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg
				></button>
                </div>
			</div>
			<div class="to-do-container">
                <% if(sect.toDos){sect.toDos.forEach((toDo, tIndex) => {%>
				<div class="to-do <%= toDo.complete && 'completed' %>" data-id="<%= toDo.id %>">
					<%if(toDo.complete) {%>
						
					<input disabled onchange="updateToDoText(<%= toDo.id %>, this.value)" class="text" value="<%= toDo.title %>" placeholder="Untitled"/>
					<% }else{ %>
					<input onchange="updateToDoText(<%= toDo.id %>, this.value)" class="text" value="<%= toDo.title %>" placeholder="Untitled"/>
					<% } %>
                    <div class="buttons">
						<button class="button complete" onclick="toggleToDoComplete(this.parentElement.parentElement)" title="<%= toDo.complete ? 'Uncomplete To Do' : 'Complete To Do' %>">
							<% if(!toDo.complete) { %>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="darkgreen"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-check-icon lucide-check"
							>
								<path d="M20 6 9 17l-5-5" /></svg>
							<% }else{ %>
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-undo-icon lucide-undo"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"/></svg>
							<% } %>
						</button>
						<button title="Move To Do" onmousedown="startMoveToDo(event, this.parentElement.parentElement, this.parentElement.parentElement.parentElement)" class="button move"
							><div id="overlay"></div><svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="black"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-grip-icon lucide-grip"
							>
								<circle cx="12" cy="5" r="1" />
								<circle cx="19" cy="5" r="1" />
								<circle cx="5" cy="5" r="1" />
								<circle cx="12" cy="12" r="1" />
								<circle cx="19" cy="12" r="1" />
								<circle cx="5" cy="12" r="1" />
								<circle cx="12" cy="19" r="1" />
								<circle cx="19" cy="19" r="1" />
								<circle cx="5" cy="19" r="1" /></svg
						></button>

						<button title="Delete To Do" class="button" onclick="deleteToDo(<%= toDo.id %>, this.parentElement.parentElement)"
							><svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="darkred"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-trash2-icon lucide-trash-2"
							>
								<path d="M10 11v6" />
								<path d="M14 11v6" />
								<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
								<path d="M3 6h18" />
								<path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg
						></button>
                    </div>
				</div>
                <% })} %>
			</div>
            <% if(sIndex != 0){ %>
                <div class="overlay" onclick="scrollToSection(<%= sect.id %>)"></div>
            <% } %>
		</div>
		<% })} %>
		<div class="spacer"></div>
	</div>
</main>
<datalist id="colors">
	<% const colors = [
	'#236F6E',
	'#278F8F',
	'#4C2A6B',
	'#6E4D8E',
	'#000099',
	'#223A5E',
	'#093a83',
	'#004400',
	'#104230',
	'#2f4f3a',
	'#570707',
	'#942020',
	'#141414',
	'#3d3d3d',
	]; 
	colors.forEach(color => {%>
	<option value="<%=color%>">
	<% }) %>
</datalist>
<script src="/js/script.js"></script>
<script>
	const selectedSection = document.querySelector('.section.selected');
	if(selectedSection){
    	selectedSection.scrollIntoView({behavior: 'auto', inline: 'center'})
	}
</script>
<%- include('partials/footer.ejs') %>
